# Скопируй этот файл в .env и вставь свой ключ.
# .env добавлен в .gitignore и НЕ попадёт в публичный репозиторий.
#
# ВНИМАНИЕ: ключ внутри мобильного приложения всё равно можно извлечь
# декомпиляцией APK. Для личного использования это допустимо. Чтобы спрятать
# ключ полностью — подними мини-прокси (см. README, раздел «Безопасность»)
# и укажи здесь URL прокси вместо прямого api.navy.

# Вариант А (просто): напрямую в NavyAI — ключ попадёт в сборку.
EXPO_PUBLIC_NAVY_BASE_URL=https://api.navy/v1
EXPO_PUBLIC_NAVY_API_KEY=sk-navy-xxxxxxxxxxxxxxxxxxxxxxxx

# Вариант Б (безопасно): через прокси-воркер (см. proxy/README.md).
# Тогда укажи URL воркера с /v1, ключ держится на сервере:
#   EXPO_PUBLIC_NAVY_BASE_URL=https://pablito-proxy.<твой>.workers.dev/v1
#   EXPO_PUBLIC_NAVY_API_KEY=not-needed
# И, если задал общий токен в воркере:
#   EXPO_PUBLIC_CLIENT_TOKEN=та-же-строка-что-в-воркере

# Модели
EXPO_PUBLIC_MODEL_CHAT=deepseek-v4-flash
EXPO_PUBLIC_MODEL_DEEP=deepseek-v4-pro
EXPO_PUBLIC_MODEL_STT=whisper-1
