{
  "expo": {
    "name": "PabLito",
    "slug": "pablito",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "pablito",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDEAE3"
    },
    "ios": {
      "bundleIdentifier": "com.stardust.pablito",
      "supportsTablet": false
    },
    "android": {
      "package": "com.stardust.pablito",
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EDEAE3"
      },
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-av",
        {
          "microphonePermission": "PabLito necesita el micrófono para escucharte hablar en español."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "PabLito quiere ver tu foto para charlar sobre ella en español."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
